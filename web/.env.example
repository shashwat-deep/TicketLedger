# TicketLedger web app — environment configuration
#
# Copy this file to `.env.local` and adjust as needed:
#   cp .env.example .env.local
#
# All values below are PUBLIC on-chain identifiers (NOT secrets):
# the address the Move package is published under and the module name.
# Vite only exposes variables prefixed with `VITE_` to client code.

# Address the TicketNFT Move package is published under.
VITE_APTOS_MODULE_ADDRESS=0xaad1cc4ea369a57f87ffaa82caf57053c8f47513a1efd0345f6b983faaacc9b2

# Name of the Move module that exposes the entry functions.
VITE_APTOS_MODULE_NAME=ticket_nft

# Target Aptos network: mainnet | testnet | devnet | local
VITE_APTOS_NETWORK=testnet
